#include <iostream>
#include <vector>
#include <queue>
using namespace std;

int dir[4][2] = {0,1,1,0,0,-1,-1,0};

//如果没有& 就是值传递 grid是一份拷贝 visited也是一份拷贝 在bfs里修改visited visited[nextx][nexty] = true; 只是改了副本 回到main后visited仍然是false 结果每个1都会被重新统计
void bfs(vector<vector<int>>& grid, vector<vector<bool>>& visited, int x, int y) {
    queue<pair<int, int>> que;
    que.push({x, y});
    visited[x][y] = 1;
    while(!que.empty()) {
        pair<int, int> cur = que.front();
        que.pop();
        int curx = cur.first;
        int cury = cur.second;
        for(int i = 0; i < 4; i++) {
            int nextx = curx + dir[i][0];
            int nexty = cury + dir[i][1];
            if(nextx < 0 || nextx >= grid.size() || nexty < 0 || nexty >= grid[0].size()) continue;
            if(!visited[nextx][nexty] && grid[nextx][nexty] == 1) {
                que.push({nextx, nexty});
                visited[nextx][nexty] = true;
            }
        }
    }
}

//在bfs函数里 每调用一次bfs都是在处理一整块连在一起的1 通过把它们都放进que里 再从que里pop出来一个一个处理；同时把visit过的都标记 所以在main函数里再次调用时要限制条件if(!visited[i][j] && grid[i][j] == 1)
int main() {
    int n, m;
    cin >> n >> m;
    vector<vector<int>> grid(n, vector<int>(m, 0));
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            cin >> grid[i][j];
        }
    }
    vector<vector<bool>> visited(n, vector<bool>(m, false));
    int res = 0; 
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            if(!visited[i][j] && grid[i][j] == 1) {
                res++;
                bfs(grid, visited, i, j);
            }
        }
    }
    cout << res << endl;
}












