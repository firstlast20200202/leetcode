#include <iostream>
#include <vector>
#include <queue>
using namespace std;

int count = 0;    //每一堆里1的个数；que里边处理的都是1，所以每推进que里一个1，就count++一次
int dir[4][2] = {1, 0, 0, 1, -1, 0, 0, -1};

void bfs(vector<vector<int>>& graph, vector<vector<bool>>& visited, int x, int y) {
    queue<pair<int, int>> que;
    que.push({x, y});
    visited[x][y] = 1;
    count++;
    while(!que.empty()) {
        pair<int, int> cur = que.front();
        que.pop();
        int curx = cur.first;
        int cury = cur.second;
        for(int i = 0; i < 4; i++) {
            int nextx = curx + dir[i][0];
            int nexty = cury + dir[i][1];
            if(nextx < 0 || nextx >= graph.size() || nexty < 0 || nexty >= graph[0].size()) continue;
            if(!visited[nextx][nexty] && graph[nextx][nexty] == 1) {    //判断当前节点的四周节点是不是valid
                que.push({nextx, nexty});
                visited[nextx][nexty] = true;
                count++;
            }
        }
    }
}

int main() {
    int n, m;
    cin >> n >> m;
    vector<vector<int>> graph(n, vector<int>(m, 0));
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            cin >> graph[i][j];
        }
    } 
    vector<vector<bool>> visited(n , vector<bool>(m, false));
    int res = 0;
    
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            if(!visited[i][j] && graph[i][j] == 1) {    //判断当前节点是不是valid 和bfs里边的这一语句不重复 因为那个是判断当前节点的四周节点是不是valid
                count = 0;
                bfs(graph, visited, i, j);
                res = max(res, count);
            }
        }
    }
    cout << res << endl;
}
