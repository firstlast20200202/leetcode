#include <iostream>
#include <vector>
using namespace std;
vector<vector<int>> result;
vector<int> path;

void dfs(const vector<vector<int>>& graph, int x, int n) {    //x is current node, n is the destination
    if(x == n) {
        result.push_back(path);
        return;
    }
    for(int i = 1; i <= n; i++) {    //traverse all the nodes that connect to x
        if(graph[x][i] == 1) {
            path.push_back(i);
            dfs(graph, i, n);
            path.pop_back();
        }
    }
    //there would be a hidden return once for loop finishes, that mean this dfs function finished execution and it goes back to the upper level dfs
}

int main() {
    int n, m, s, t;
    cin >> n >> m;

    vector<vector<int>> graph(n + 1, vector<int>(n + 1, 0));

    while(m--) {
        cin >> s >> t;
        graph[s][t] = 1;
    }

    path.push_back(1);
    dfs(graph, 1, n);

    //output
    if(result.size() == 0) cout << -1 << endl;
    for(const vector<int> &pa : result) {
        for(int i = 0; i < pa.size() - 1; i++) {
            cout << pa[i] << " ";
        }
        cout << pa[pa.size() - 1] << endl;
    }
}
